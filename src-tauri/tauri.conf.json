{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "App Launcher",
  "version": "0.2.0",
  "identifier": "com.dougb.applauncher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "widget",
        "url": "widget.html",
        "title": "App Launcher",
        "width": 110,
        "height": 80,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "x": 100,
        "y": 100
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBMkJCMzVFNjZFQjFEQzUKUldURkhldG1Yck1yZWdlcGtzdDBTdEZqbnhTYmU2OUFxN3cvWTVXYVJwOUFCcGN0bElGVXZ6THMK",
      "endpoints": [
        "https://tonic-tech.com/app-launcher/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "TonicTech",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
